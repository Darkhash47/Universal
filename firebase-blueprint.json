{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Academy operative identity node with progression data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string", "description": "Unique identifiers for login." },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["student", "admin"],
          "default": "student"
        },
        "disabled": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "role", "createdAt"]
    },
    "AuthLog": {
      "title": "Authentication Log",
      "description": "Record of security access events.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "event": { "type": "string", "enum": ["LOGIN_SUCCESS", "LOGIN_FAILURE", "LOGOUT"] },
        "ip": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "event", "timestamp"]
    },
    "News": {
      "title": "News Feed",
      "description": "Cybersecurity updates and project announcements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["CYBER_NEWS", "PROJECT_UPDATE", "ANNOUNCEMENT", "CTF_EVENT"] },
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "type", "createdAt"]
    },
    "Task": {
      "title": "Academy Task",
      "description": "Weekly challenges and missions for cadets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "rewardXP": { "type": "number" },
        "difficulty": { "type": "string", "enum": ["EASY", "MEDIUM", "HARD", "INSANE"] },
        "category": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "rewardXP", "difficulty", "category"]
    },
    "Submission": {
      "title": "Task Submission",
      "description": "User write-up and proof for completed tasks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "reviewedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "userId", "content", "status", "createdAt"]
    },
    "Team": {
      "title": "Squad",
      "description": "Collaborative units of operatives.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "leaderId": { "type": "string" },
        "memberCount": { "type": "number" },
        "totalPoints": { "type": "number" },
        "logoUrl": { "type": "string" }
      },
      "required": ["name", "leaderId"]
    },
    "VerificationRequest": {
      "title": "Verification Request",
      "description": "Legacy identity verification protocol request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "createdAt"]
    },
    "SkillCatalogNode": {
      "title": "Skill Catalog Node",
      "description": "A node in the Hard Skills knowledge graph.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Basic", "Intermediate", "Professional", "Expert"] },
        "resourceLink": { "type": "string" }
      },
      "required": ["title", "description", "category", "difficulty", "resourceLink"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User identity node data."
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Global news feed."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Available missions."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Submitted reports."
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Squad data."
    },
    "/verifications/{requestId}": {
      "schema": "VerificationRequest",
      "description": "Legacy verification protocols."
    },
    "/auth_logs/{logId}": {
      "schema": "AuthLog",
      "description": "Security audit logs for authentication events."
    },
    "/skills_catalog/{nodeId}": {
      "schema": "SkillCatalogNode",
      "description": "Nodes for the Hard Skills interactive roadmap."
    }
  }
}
