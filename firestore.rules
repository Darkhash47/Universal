rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        (request.auth.token.email == "hashmatrix.sec@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'displayName', 'email', 'role']) &&
               data.uid is string && data.uid.size() <= 128 &&
               data.displayName is string && data.displayName.size() <= 128 &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['CADET', 'CURATOR', 'COORDINATOR', 'ADMIN'];
      }

      allow get: if true;
      allow list: if true;

      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId && incoming().role == 'CADET';
      
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'title', 'bio', 'hardSkills', 'softSkills', 'experience', 'teamId'])
      )) || isAdmin();
    }

    // --- News Collection ---
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin() || isRole('COORDINATOR');
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isRole('COORDINATOR') || isRole('CURATOR');
    }

    // --- Submissions Collection ---
    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin() || isRole('CURATOR'));
      allow list: if isSignedIn() && (isAdmin() || isRole('CURATOR') || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'PENDING';
      allow update: if isAdmin() || isRole('CURATOR');
    }

    // --- Teams Collection ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isRole('COORDINATOR');
    }

    // --- Verifications Collection ---
    match /verifications/{requestId} {
      function isValidVerification(data) {
        return data.keys().hasAll(['userId', 'certificateName', 'status', 'createdAt']) &&
               data.userId is string && data.userId.size() <= 128 &&
               data.certificateName is string && data.certificateName.size() <= 256 &&
               data.status in ['PENDING', 'VERIFIED', 'REJECTED'] &&
               data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100) && (
        isAdmin() || resource.data.userId == request.auth.uid
      );

      allow create: if isSignedIn() && isEmailVerified() && isValidVerification(incoming()) && incoming().userId == request.auth.uid && incoming().status == 'PENDING' && incoming().createdAt == request.time;
      
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasAll(['status', 'processedAt']) &&
        incoming().status in ['VERIFIED', 'REJECTED'] &&
        incoming().processedAt == request.time
      );

      allow delete: if isAdmin();
    }

    // --- Admins Collection ---
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or specialized system
    }
  }
}
